# Copy to .env and adjust for your machine. Values below match docker-compose.yml defaults.

# Schema owner / admin role. Used ONLY by the Prisma CLI to run migrations
# (CREATE TABLE, CREATE POLICY, GRANT). Never used by the running app.
DATABASE_URL="postgresql://postgres:postgres_dev_password@localhost:5432/plexo?schema=public"

# Restricted runtime role (NOSUPERUSER, NOBYPASSRLS, see docker/postgres-init/01-init-roles.sql).
# This is what the NestJS API actually connects with, so RLS policies apply to it.
APP_DATABASE_URL="postgresql://plexo_app:plexo_dev_password@localhost:5432/plexo?schema=public"

# Generate your own: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-me-with-a-random-64-char-hex-string"
JWT_EXPIRES_IN="8h"

PORT=3000
