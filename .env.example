# Copy to .env and adjust for your machine. Values below match docker-compose.yml defaults.

# Schema owner / admin role. Used ONLY by the Prisma CLI to run migrations
# (CREATE TABLE, CREATE POLICY, GRANT). Never used by the running app.
DATABASE_URL="postgresql://postgres:postgres_dev_password@localhost:5432/plexo?schema=public"

# Restricted runtime role (NOSUPERUSER, NOBYPASSRLS, see docker/postgres-init/01-init-roles.sql).
# This is what the NestJS API actually connects with, so RLS policies apply to it.
APP_DATABASE_URL="postgresql://plexo_app:plexo_dev_password@localhost:5432/plexo?schema=public"

# Generate your own: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-me-with-a-random-64-char-hex-string"
JWT_EXPIRES_IN="8h"

PORT=3000

# Optional. Without these, invoice emails are only logged (ConsoleEmailSender),
# not sent - fine for local dev. Get a key at https://resend.com, and either
# verify your own sending domain or use their sandbox address for testing.
RESEND_API_KEY=""
EMAIL_FROM="facturas@tudominio.com"

# Optional. Without all three, the "Buscar en AFIP" button on the Empresa
# form fails with a clear "not configured" error (StubAfipPadronService) -
# fine for local dev. Needs an AFIP digital certificate authorized for the
# "Padrón" (ws_sr_padron_a13) service via Administrador de Relaciones de
# Clave Fiscal (https://www.afip.gob.ar), not the same authorization as
# real electronic invoicing (WSFE). Point the *_PATH vars at PEM files on
# disk (not inline, to avoid multi-line .env escaping).
AFIP_CERT_PATH=""
AFIP_KEY_PATH=""
# The CUIT the certificate above is registered under - this is who's
# "asking", not the CUIT being looked up.
AFIP_CUIT_REPRESENTADA=""
# "homologacion" (AFIP's sandbox, default) or "produccion".
AFIP_ENV="homologacion"
