generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  SALES
  INVENTORY
  ACCOUNTANT
  VIEWER
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum UnitOfMeasure {
  KG
  LTR
  MM
  M2
  UNIT
}

enum MovementType {
  PURCHASE_IN
  SALE_OUT
  RETURN
  ADJUSTMENT
  PRODUCTION_IN
  PRODUCTION_OUT
}

enum AuditAction {
  INSERT
  UPDATE
  DELETE
}

// AFIP comprobante letter. Applies to both Invoice and CreditNote - the
// model itself (Invoice vs CreditNote) already says which kind of document
// it is, so this only needs to carry the letter, not "CREDIT_NOTE_A" etc.
enum DocumentLetter {
  A
  B
  C
  M
}

enum DiscountType {
  PERCENTAGE
  AMOUNT
}

enum TaxCalculationType {
  PERCENTAGE
  FIXED_AMOUNT
  FORMULA
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalLineDirection {
  DEBIT
  CREDIT
}

enum FinancialAccountProvider {
  BANK
  MERCADOPAGO
  PAYPAL
  CASH
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  taxId     String?
  createdAt DateTime @default(now())

  @@map("tenants")
}

model User {
  id                   String   @id @default(uuid())
  tenantId             String
  email                String
  passwordHash         String
  role                 UserRole @default(VIEWER)
  isExternalAccountant Boolean  @default(false)
  name                 String?
  avatarUrl            String?
  // Opt-in: whether this user's online/offline state is broadcast to
  // tenant-mates over the dashboard WebSocket (see DashboardGateway).
  // Off by default would mean nobody's presence shows until they opt in;
  // on by default matches how presence indicators normally work elsewhere
  // and is easy to turn off from the profile screen.
  showOnlinePresence   Boolean  @default(true)
  createdAt            DateTime @default(now())

  moduleAccess          UserModuleAccess[]
  issuedInvoices        Invoice[]
  issuedCreditNotes     CreditNote[]
  createdJournalEntries JournalEntry[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model UserModuleAccess {
  id       String  @id @default(uuid())
  tenantId String
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  module   String
  canRead  Boolean @default(true)
  canWrite Boolean @default(false)

  @@unique([userId, module])
  @@index([tenantId])
  @@map("user_module_access")
}

enum CompanyRoleType {
  CUSTOMER
  SUPPLIER
  BRANCH
}

// Unifies what used to be a Customer-only table: any external company the
// tenant deals with (as a customer and/or a supplier) plus the tenant's
// own branches/points of sale - all three are "a company", just playing
// different roles (see CompanyRole, many-to-many: a distributor can be
// both a customer and a supplier at once). pointOfSaleNumber only means
// something for a BRANCH (the AFIP punto de venta invoices are issued
// under); it's simply unused for CUSTOMER/SUPPLIER rows.
model Company {
  id                String   @id @default(uuid())
  tenantId          String
  name              String
  taxId             String?
  email             String?
  creditLimit       Decimal  @default(0) @db.Decimal(14, 2)
  pointOfSaleNumber String?
  createdAt         DateTime @default(now())

  roles  CompanyRole[]
  people Person[]

  // Relation field on Invoice/Quote is kept named `customer` (not renamed
  // to `company`) so every existing `include: { customer: true }` /
  // `invoice.customer.name` call site across Invoicing/Receivables/Reports
  // keeps working unchanged - only the model/table the FK targets changed.
  invoices Invoice[]
  quotes   Quote[]

  @@index([tenantId])
  @@map("companies")
}

model CompanyRole {
  id        String          @id @default(uuid())
  tenantId  String
  companyId String
  company   Company         @relation(fields: [companyId], references: [id])
  role      CompanyRoleType

  @@unique([tenantId, companyId, role])
  @@index([tenantId, role])
  @@map("company_roles")
}

// Contact person at a customer or supplier company (not meaningful for a
// BRANCH - that's the tenant's own location, not an external contact).
// Nothing enforces that at the schema level; CompaniesService is where
// that rule actually lives.
model Person {
  id        String   @id @default(uuid())
  tenantId  String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  firstName String
  lastName  String?
  nickname  String?
  email     String?
  whatsapp  String?
  avatarUrl String?
  jobTitle  String?
  createdAt DateTime @default(now())

  @@index([tenantId, companyId])
  @@map("people")
}

// --- Currency ---

// Pricing reference is USD (ArticleVariant.unitPrice) per the invoicing
// design; invoices are denominated in whichever Currency the tenant issues
// in (typically ARS), converting at Invoice.exchangeRate - which is locked
// at issuance, never recomputed from here afterward.
model Currency {
  id       String  @id @default(uuid())
  tenantId String
  code     String
  name     String
  isBase   Boolean @default(false)

  exchangeRates ExchangeRateHistory[]
  invoices      Invoice[]
  creditNotes   CreditNote[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("currencies")
}

// Append-only, like PriceHistory - never update a rate in place, insert a
// new one. Rate is expressed as units of `currency` per 1 USD.
model ExchangeRateHistory {
  id          String   @id @default(uuid())
  tenantId    String
  currencyId  String
  currency    Currency @relation(fields: [currencyId], references: [id])
  rate        Decimal  @db.Decimal(18, 6)
  effectiveAt DateTime @default(now())

  @@index([tenantId, currencyId, effectiveAt])
  @@map("exchange_rate_history")
}

// --- Inventory ---

// Self-referential so category depth isn't hardcoded to 2 levels
// (Category/Subcategory) - a chain of parentId links supports any depth
// without a schema change later.
model Category {
  id       String     @id @default(uuid())
  tenantId String
  name     String
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  articles Article[]

  @@unique([tenantId, parentId, name])
  @@index([tenantId])
  @@map("categories")
}

// The catalog-level entry (name, unit, category, tax). Never sold or
// stocked directly - ArticleVariant is the sellable/stocked unit, even
// for articles with no real variation (see ArticleVariant comment).
model Article {
  id              String         @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  unitOfMeasure   UnitOfMeasure  @default(UNIT)
  categoryId      String?
  category        Category?      @relation(fields: [categoryId], references: [id])
  taxDefinitionId String?
  taxDefinition   TaxDefinition? @relation(fields: [taxDefinitionId], references: [id])
  createdAt       DateTime       @default(now())

  variants ArticleVariant[]

  @@index([tenantId])
  @@map("articles")
}

// The actual SKU-bearing, priced, stocked unit. An Article with no real
// variation still gets exactly one ArticleVariant (its "default" SKU) -
// this keeps stock/price/movement logic uniform instead of special-casing
// "articles without variants" throughout the codebase.
model ArticleVariant {
  id        String   @id @default(uuid())
  tenantId  String
  articleId String
  article   Article  @relation(fields: [articleId], references: [id])
  sku       String
  color     String?
  size      String?
  brand     String?
  unitPrice Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())

  priceHistory  PriceHistory[]
  stockLedger   StockLedger[]
  minimumStocks MinimumStock[]
  movements     StockMovement[]
  invoiceLines  InvoiceLine[]
  quoteLines    QuoteLine[]

  @@unique([tenantId, sku])
  @@index([tenantId, articleId])
  @@map("article_variants")
}

// Append-only price timeline, separate from AuditLog: this is a narrow,
// query-friendly table purpose-built for cost/margin-over-time reports,
// not a generic diff log.
model PriceHistory {
  id               String         @id @default(uuid())
  tenantId         String
  articleVariantId String
  articleVariant   ArticleVariant @relation(fields: [articleVariantId], references: [id])
  unitPrice        Decimal        @db.Decimal(14, 2)
  costPrice        Decimal?       @db.Decimal(14, 2)
  changedById      String?
  effectiveAt      DateTime       @default(now())

  @@index([tenantId, articleVariantId])
  @@map("price_history")
}

model Warehouse {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  location String?

  stockLedger   StockLedger[]
  minimumStocks MinimumStock[]
  movements     StockMovement[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("warehouses")
}

// Current balance per (warehouse, variant) - materialized and kept in sync
// with every StockMovement in the same DB transaction. StockMovement is the
// source of truth/history; this is the fast-read projection of it, not an
// independently-editable value.
model StockLedger {
  id               String         @id @default(uuid())
  tenantId         String
  warehouseId      String
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id])
  articleVariantId String
  articleVariant   ArticleVariant @relation(fields: [articleVariantId], references: [id])
  quantity         Decimal        @default(0) @db.Decimal(14, 3)
  updatedAt        DateTime       @updatedAt

  @@unique([warehouseId, articleVariantId])
  @@index([tenantId])
  @@map("stock_ledger")
}

model MinimumStock {
  id               String         @id @default(uuid())
  tenantId         String
  warehouseId      String
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id])
  articleVariantId String
  articleVariant   ArticleVariant @relation(fields: [articleVariantId], references: [id])
  minimumQuantity  Decimal        @db.Decimal(14, 3)

  @@unique([warehouseId, articleVariantId])
  @@index([tenantId])
  @@map("minimum_stock")
}

// Immutable history of every stock in/out. sourceType/sourceId is a soft
// (non-FK) pointer to whatever originated it (purchase order, production
// order, manual adjustment...) since that can be any table; invoiceId stays
// a real FK for the sales path specifically, since Invoice already models
// that relation elsewhere (Invoice.movements).
model StockMovement {
  id               String         @id @default(uuid())
  tenantId         String
  warehouseId      String
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id])
  articleVariantId String
  articleVariant   ArticleVariant @relation(fields: [articleVariantId], references: [id])
  type             MovementType
  quantity         Decimal        @db.Decimal(14, 3)
  sourceType       String?
  sourceId         String?
  invoiceId        String?
  invoice          Invoice?       @relation(fields: [invoiceId], references: [id])
  createdAt        DateTime       @default(now())

  @@index([tenantId])
  @@index([tenantId, articleVariantId])
  @@map("stock_movements")
}

// Populated exclusively by Postgres triggers (see the
// row_level_security/audit migrations), never by application code - see
// the inventory module notes on why triggers instead of Prisma middleware.
model AuditLog {
  id        String      @id @default(uuid())
  tenantId  String
  tableName String
  recordId  String
  action    AuditAction
  changedBy String?
  changes   Json
  createdAt DateTime    @default(now())

  @@index([tenantId, tableName, recordId])
  @@map("audit_log")
}

enum ActivityOutcome {
  SUCCESS
  FAILURE
}

// Application-level "who did what, when, from where" log - distinct from
// AuditLog above, which is a DB-trigger row-change log with no IP/session
// info (that only exists at the HTTP layer, triggers can't see it).
// Populated by ActivityLogInterceptor (apps/api) for mutating requests,
// and directly by AuthService for login attempts specifically, since
// those happen before TenantContextInterceptor establishes any context
// for the interceptor to piggyback on.
model UserActivityLog {
  id           String          @id @default(uuid())
  tenantId     String
  userId       String?
  action       String
  outcome      ActivityOutcome
  ip           String?
  userAgent    String?
  errorMessage String?
  createdAt    DateTime        @default(now())

  @@index([tenantId, createdAt])
  @@map("user_activity_log")
}

// Once afipCae is set, this row is fiscally locked (see the
// invoice-immutability migration): every column except balanceDue/status
// becomes read-only, even for admins. Corrections after that point are a
// CreditNote referencing this invoice, never an UPDATE.
model Invoice {
  id                    String         @id @default(uuid())
  tenantId              String
  customerId            String
  customer              Company        @relation(fields: [customerId], references: [id])
  // Snapshot of the customer at issuance - required for fiscal documents:
  // Company.name/taxId can change later, the invoice must not silently
  // change with it.
  customerName          String
  customerTaxId         String?
  documentLetter        DocumentLetter
  pointOfSale           String
  number                String
  status                InvoiceStatus  @default(DRAFT)
  issueDate             DateTime       @default(now())
  dueDate               DateTime?
  currencyId            String
  currency              Currency       @relation(fields: [currencyId], references: [id])
  // USD -> currency, locked at issuance - never recompute retroactively.
  exchangeRate          Decimal        @db.Decimal(18, 6)
  globalDiscountPercent Decimal        @default(0) @db.Decimal(5, 2)
  subtotal              Decimal        @db.Decimal(14, 2)
  taxTotal              Decimal        @db.Decimal(14, 2)
  total                 Decimal        @db.Decimal(14, 2)
  balanceDue            Decimal        @db.Decimal(14, 2)
  afipCae               String?
  afipCaeExpiry         DateTime?
  issuedByUserId        String
  issuedBy              User           @relation(fields: [issuedByUserId], references: [id])

  lines        InvoiceLine[]
  movements    StockMovement[]
  journalEntry JournalEntry?
  receipts     Receipt[]
  creditNotes  CreditNote[]

  @@unique([tenantId, documentLetter, pointOfSale, number])
  @@index([tenantId, customerId])
  @@map("invoices")
}

model InvoiceLine {
  id               String         @id @default(uuid())
  tenantId         String
  invoiceId        String
  invoice          Invoice        @relation(fields: [invoiceId], references: [id])
  articleVariantId String
  articleVariant   ArticleVariant @relation(fields: [articleVariantId], references: [id])
  quantity         Decimal        @db.Decimal(14, 3)
  // Already converted to the invoice's currency (articleVariant.unitPrice
  // in USD x Invoice.exchangeRate), before any discount.
  unitPrice        Decimal        @db.Decimal(14, 2)
  discountType     DiscountType   @default(PERCENTAGE)
  discountValue    Decimal        @default(0) @db.Decimal(14, 2)
  // quantity*unitPrice net of discountType/discountValue, pre-tax,
  // pre-global-discount - kept for auditability instead of only storing
  // the final lineTotal, since the calculation chain has multiple stages.
  netAmount        Decimal        @db.Decimal(14, 2)
  taxRate          Decimal        @db.Decimal(5, 2)
  lineTotal        Decimal        @db.Decimal(14, 2)

  @@index([tenantId])
  @@map("invoice_lines")
}

// A correction to an already-issued Invoice. Never an UPDATE to the
// original - the trigger enforces that once an Invoice has a CAE, it's
// read-only, so any adjustment (return, pricing error, cancellation) has
// to be its own fiscal document, linked back via invoiceId.
model CreditNote {
  id             String         @id @default(uuid())
  tenantId       String
  invoiceId      String
  invoice        Invoice        @relation(fields: [invoiceId], references: [id])
  documentLetter DocumentLetter
  pointOfSale    String
  number         String
  reason         String
  currencyId     String
  currency       Currency       @relation(fields: [currencyId], references: [id])
  exchangeRate   Decimal        @db.Decimal(18, 6)
  subtotal       Decimal        @db.Decimal(14, 2)
  taxTotal       Decimal        @db.Decimal(14, 2)
  total          Decimal        @db.Decimal(14, 2)
  afipCae        String?
  afipCaeExpiry  DateTime?
  issuedByUserId String
  issuedBy       User           @relation(fields: [issuedByUserId], references: [id])
  issueDate      DateTime       @default(now())

  @@unique([tenantId, documentLetter, pointOfSale, number])
  @@index([tenantId, invoiceId])
  @@map("credit_notes")
}

model Quote {
  id              String    @id @default(uuid())
  tenantId        String
  customerId      String
  customer        Company   @relation(fields: [customerId], references: [id])
  number          String
  status          String    @default("DRAFT")
  brandingLogoUrl String?
  validUntil      DateTime?
  total           Decimal   @db.Decimal(14, 2)

  lines QuoteLine[]

  @@unique([tenantId, number])
  @@map("quotes")
}

model QuoteLine {
  id               String         @id @default(uuid())
  tenantId         String
  quoteId          String
  quote            Quote          @relation(fields: [quoteId], references: [id])
  articleVariantId String
  articleVariant   ArticleVariant @relation(fields: [articleVariantId], references: [id])
  quantity         Decimal        @db.Decimal(14, 3)
  unitPrice        Decimal        @db.Decimal(14, 2)

  @@index([tenantId])
  @@map("quote_lines")
}

model Receipt {
  id                 String            @id @default(uuid())
  tenantId           String
  invoiceId          String
  invoice            Invoice           @relation(fields: [invoiceId], references: [id])
  amount             Decimal           @db.Decimal(14, 2)
  method             String
  financialAccountId String?
  financialAccount   FinancialAccount? @relation(fields: [financialAccountId], references: [id])
  paidAt             DateTime          @default(now())

  @@map("receipts")
}

model AccountingAccount {
  id       String      @id @default(uuid())
  tenantId String
  code     String
  name     String
  type     AccountType

  lines JournalEntryLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("accounting_accounts")
}

// Posted entries are immutable (see the journal-entry-lock migration) -
// correcting one is a reversing entry (same lines, DEBIT/CREDIT swapped),
// linked via reversalOfId, never an UPDATE to the original.
model JournalEntry {
  id           String        @id @default(uuid())
  tenantId     String
  invoiceId    String?       @unique
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id])
  description  String
  date         DateTime      @default(now())
  createdById  String
  createdBy    User          @relation(fields: [createdById], references: [id])
  reversalOfId String?       @unique
  reversalOf   JournalEntry? @relation("EntryReversal", fields: [reversalOfId], references: [id])
  reversedBy   JournalEntry? @relation("EntryReversal")

  lines JournalEntryLine[]

  @@index([tenantId])
  @@map("journal_entries")
}

// One line = one account + one direction + one amount (the standard
// double-entry shape) - NOT a debit account and a credit account on the
// same row, which can't express a compound entry (e.g. one debit split
// across several credit accounts of different amounts).
model JournalEntryLine {
  id             String               @id @default(uuid())
  tenantId       String
  journalEntryId String
  journalEntry   JournalEntry         @relation(fields: [journalEntryId], references: [id])
  accountId      String
  account        AccountingAccount    @relation(fields: [accountId], references: [id])
  direction      JournalLineDirection
  amount         Decimal              @db.Decimal(14, 2)

  @@index([tenantId])
  @@index([tenantId, accountId])
  @@map("journal_entry_lines")
}

// Versioned by design: never edit `rate`/`formula` on a definition that's
// already been used by an issued invoice - close it with `validTo` and
// create a new row instead. That's what lets a tax change (IVA 21% ->
// 22%, a new IIBB rate) apply going forward without altering the frozen
// calculation on documents already issued.
model TaxDefinition {
  id                  String             @id @default(uuid())
  tenantId            String
  code                String
  name                String
  calculationType     TaxCalculationType @default(PERCENTAGE)
  rate                Decimal?           @db.Decimal(5, 2)
  fixedAmount         Decimal?           @db.Decimal(14, 2)
  formula             String?
  validFrom           DateTime           @default(now())
  validTo             DateTime?
  managedByAccountant Boolean            @default(false)

  articles Article[]

  @@unique([tenantId, code, validFrom])
  @@index([tenantId])
  @@map("tax_definitions")
}

model FinancialAccount {
  id             String                   @id @default(uuid())
  tenantId       String
  name           String
  provider       FinancialAccountProvider
  currentBalance Decimal                  @default(0) @db.Decimal(14, 2)

  receipts     Receipt[]
  transactions FinancialTransaction[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("financial_accounts")
}

model FinancialTransaction {
  id                 String           @id @default(uuid())
  tenantId           String
  financialAccountId String
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id])
  amount             Decimal          @db.Decimal(14, 2)
  reconciled         Boolean          @default(false)
  externalRef        String?
  occurredAt         DateTime         @default(now())

  @@index([tenantId])
  @@map("financial_transactions")
}
