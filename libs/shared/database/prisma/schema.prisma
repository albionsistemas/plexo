generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  SALES
  INVENTORY
  ACCOUNTANT
  VIEWER
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum MovementType {
  PURCHASE_IN
  SALE_OUT
  ADJUSTMENT
  RETURN
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  taxId     String?
  createdAt DateTime @default(now())

  @@map("tenants")
}

model User {
  id                   String   @id @default(uuid())
  tenantId             String
  email                String
  passwordHash         String
  role                 UserRole @default(VIEWER)
  isExternalAccountant Boolean  @default(false)
  createdAt            DateTime @default(now())

  moduleAccess UserModuleAccess[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model UserModuleAccess {
  id       String  @id @default(uuid())
  tenantId String
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  module   String
  canRead  Boolean @default(true)
  canWrite Boolean @default(false)

  @@unique([userId, module])
  @@index([tenantId])
  @@map("user_module_access")
}

model Customer {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  taxId       String?
  email       String?
  creditLimit Decimal  @default(0) @db.Decimal(14, 2)
  createdAt   DateTime @default(now())

  invoices Invoice[]
  quotes   Quote[]

  @@index([tenantId])
  @@map("customers")
}

model Product {
  id          String     @id @default(uuid())
  tenantId    String
  sku         String
  name        String
  unitPrice   Decimal    @db.Decimal(14, 2)
  stockQty    Decimal    @default(0) @db.Decimal(14, 3)
  taxConfigId String?
  taxConfig   TaxConfig? @relation(fields: [taxConfigId], references: [id])

  invoiceLines InvoiceLine[]
  movements    StockMovement[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

model StockMovement {
  id        String       @id @default(uuid())
  tenantId  String
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  type      MovementType
  quantity  Decimal      @db.Decimal(14, 3)
  invoiceId String?
  invoice   Invoice?     @relation(fields: [invoiceId], references: [id])
  createdAt DateTime     @default(now())

  @@index([tenantId])
  @@map("stock_movements")
}

model Invoice {
  id            String        @id @default(uuid())
  tenantId      String
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  number        String
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  subtotal      Decimal       @db.Decimal(14, 2)
  taxTotal      Decimal       @db.Decimal(14, 2)
  total         Decimal       @db.Decimal(14, 2)
  balanceDue    Decimal       @db.Decimal(14, 2)
  afipCae       String?
  afipCaeExpiry DateTime?

  lines        InvoiceLine[]
  movements    StockMovement[]
  journalEntry JournalEntry?
  receipts     Receipt[]

  @@unique([tenantId, number])
  @@index([tenantId, customerId])
  @@map("invoices")
}

model InvoiceLine {
  id        String  @id @default(uuid())
  tenantId  String
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Decimal @db.Decimal(14, 3)
  unitPrice Decimal @db.Decimal(14, 2)
  taxRate   Decimal @db.Decimal(5, 2)
  lineTotal Decimal @db.Decimal(14, 2)

  @@index([tenantId])
  @@map("invoice_lines")
}

model Quote {
  id              String    @id @default(uuid())
  tenantId        String
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  number          String
  status          String    @default("DRAFT")
  brandingLogoUrl String?
  validUntil      DateTime?
  total           Decimal   @db.Decimal(14, 2)

  lines QuoteLine[]

  @@unique([tenantId, number])
  @@map("quotes")
}

model QuoteLine {
  id        String  @id @default(uuid())
  tenantId  String
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id])
  productId String
  quantity  Decimal @db.Decimal(14, 3)
  unitPrice Decimal @db.Decimal(14, 2)

  @@index([tenantId])
  @@map("quote_lines")
}

model Receipt {
  id                 String            @id @default(uuid())
  tenantId           String
  invoiceId          String
  invoice            Invoice           @relation(fields: [invoiceId], references: [id])
  amount             Decimal           @db.Decimal(14, 2)
  method             String
  financialAccountId String?
  financialAccount   FinancialAccount? @relation(fields: [financialAccountId], references: [id])
  paidAt             DateTime          @default(now())

  @@map("receipts")
}

model AccountingAccount {
  id       String @id @default(uuid())
  tenantId String
  code     String
  name     String
  type     String

  linesDebit  JournalEntryLine[] @relation("debitAccount")
  linesCredit JournalEntryLine[] @relation("creditAccount")

  @@unique([tenantId, code])
  @@map("accounting_accounts")
}

model JournalEntry {
  id          String   @id @default(uuid())
  tenantId    String
  invoiceId   String?  @unique
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  description String
  date        DateTime @default(now())
  createdById String

  lines JournalEntryLine[]

  @@map("journal_entries")
}

model JournalEntryLine {
  id              String             @id @default(uuid())
  tenantId        String
  journalEntryId  String
  journalEntry    JournalEntry       @relation(fields: [journalEntryId], references: [id])
  debitAccountId  String?
  debitAccount    AccountingAccount? @relation("debitAccount", fields: [debitAccountId], references: [id])
  creditAccountId String?
  creditAccount   AccountingAccount? @relation("creditAccount", fields: [creditAccountId], references: [id])
  amount          Decimal            @db.Decimal(14, 2)

  @@index([tenantId])
  @@map("journal_entry_lines")
}

model TaxConfig {
  id                  String  @id @default(uuid())
  tenantId            String
  name                String
  rate                Decimal @db.Decimal(5, 2)
  managedByAccountant Boolean @default(false)

  products Product[]

  @@map("tax_configs")
}

model FinancialAccount {
  id             String  @id @default(uuid())
  tenantId       String
  name           String
  provider       String
  currentBalance Decimal @default(0) @db.Decimal(14, 2)

  receipts     Receipt[]
  transactions FinancialTransaction[]

  @@map("financial_accounts")
}

model FinancialTransaction {
  id                 String           @id @default(uuid())
  tenantId           String
  financialAccountId String
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id])
  amount             Decimal          @db.Decimal(14, 2)
  reconciled         Boolean          @default(false)
  externalRef        String?
  occurredAt         DateTime         @default(now())

  @@index([tenantId])
  @@map("financial_transactions")
}
